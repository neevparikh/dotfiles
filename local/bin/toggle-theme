#!/usr/bin/env bash

if [[ $@ = "--dark" ]] 
then
    kitty @ --to $SOCKET set-colors --all --configured $DARK_KITTY
    echo 'dark' > $HOME/.config/theme.yaml
elif [[ $@ = "--light" ]] 
then
    kitty @ --to $SOCKET set-colors --all --configured $LIGHT_KITTY
    echo 'light' > $HOME/.config/theme.yaml
fi 
