#!/usr/bin/env python3

import subprocess
from pprint import pprint

COMMAND = "sudo /usr/bin/wdutil info"
SEP = "————————————————————————————————————————————————————————————————————"


def process_section(section_str: str) -> dict[str, str]:
    key_value_pairs = [p.strip().split(" : ") for p in section_str.split("\n") if p]
    key_value_pairs = [[sp.strip() for sp in p] for p in key_value_pairs if len(p) == 2]
    return {k: v for k, v in key_value_pairs}


def get_all_info() -> dict[str, dict[str, str]]:
    output = subprocess.run(COMMAND, shell=True, capture_output=True)
    decoded = output.stdout.decode("utf-8")
    parts = [p.strip() for p in decoded.split(SEP) if p]
    parsed = {
        section: vals
        for section, vals in map(
            lambda kv: (kv[0], process_section(kv[1])),
            zip(parts[0 : len(parts) - 1 : 2], parts[1 : len(parts) : 2]),
        )
    }
    return parsed


def get_wifi_info() -> dict[str, str]:
    return get_all_info()["WIFI"]


if __name__ == "__main__":
    for k, v in get_wifi_info().items():
        print(f"{k}: {v}")
