# vim:fileencoding=utf-8:ft=conf:foldmethod=marker:foldlevel=0

# -- {{{ mode
:: resize

default < alt - r ; resize

resize < alt - r ; default
resize < escape ; default
# -- }}}
# -- {{{ yabai
# relaunch
cmd + alt + shift - r : yabai --restart-service && brew services restart sketchybar && skhd --reload

# rebalance
cmd + shift - r : yabai -m space --balance

# movement
cmd - h : yabai -m window --focus west
cmd - j : yabai -m window --focus stack.next || yabai -m window --focus south
cmd - k : yabai -m window --focus stack.prev || yabai -m window --focus north
cmd - l : yabai -m window --focus east

cmd + shift - h : yabai_move west
cmd + shift - j : yabai_move south
cmd + shift - k : yabai_move north
cmd + shift - l : yabai_move east

cmd + shift - 1 : yabai -m window --space 1
cmd + shift - 2 : yabai -m window --space 2
cmd + shift - 3 : yabai -m window --space 3
cmd + shift - 4 : yabai -m window --space 4
cmd + shift - 5 : yabai -m window --space 5
cmd + shift - 6 : yabai -m window --space 6
cmd + shift - 7 : yabai -m window --space 7
cmd + shift - 8 : yabai -m window --space 8
cmd + shift - 9 : yabai -m window --space 9
cmd + shift - 0 : yabai -m window --space 10
alt + shift - 1 : yabai -m window --space 11
alt + shift - 2 : yabai -m window --space 12
alt + shift - 3 : yabai -m window --space 13
alt + shift - 4 : yabai -m window --space 14
alt + shift - 5 : yabai -m window --space 15
alt + shift - 6 : yabai -m window --space 16

# spaces
cmd - 1 : yabai -m space --focus 1
cmd - 2 : yabai -m space --focus 2
cmd - 3 : yabai -m space --focus 3
cmd - 4 : yabai -m space --focus 4
cmd - 5 : yabai -m space --focus 5
cmd - 6 : yabai -m space --focus 6
cmd - 7 : yabai -m space --focus 7
cmd - 8 : yabai -m space --focus 8
cmd - 9 : yabai -m space --focus 9
cmd - 0 : yabai -m space --focus 10
alt - 1 : yabai -m space --focus 11
alt - 2 : yabai -m space --focus 12
alt - 3 : yabai -m space --focus 13
alt - 4 : yabai -m space --focus 14
alt - 5 : yabai -m space --focus 15
alt - 6 : yabai -m space --focus 16

# toggle zoom + float
alt + shift - d : yabai -m window --toggle zoom-parent
alt + shift - f : yabai -m window --toggle zoom-fullscreen
alt + shift - e : yabai -m window --toggle split
ctrl - f : yabai -m window --toggle float --grid 4:4:1:1:2:2

# tiling
ctrl - e : yabai -m space --layout bsp
ctrl - s : yabai -m space --layout stack

# resizing
resize < h : yabai -m window --resize left:-30:0 ; yabai -m window --resize right:-30:0
resize < j : yabai -m window --resize bottom:0:30 ; yabai -m window --resize top:0:30
resize < k : yabai -m window --resize top:0:-30 ; yabai -m window --resize bottom:0:-30
resize < l : yabai -m window --resize right:30:0 ; yabai -m window --resize left:30:0
# -- }}}
# -- {{{ applications   
cmd + shift - return : $HOME/.local/bin/terminal
cmd + shift - w : $HOME/.local/bin/browser
# -- }}}

