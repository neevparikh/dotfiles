# -- {{{ setup
source "$HOME/.config/sketchybar/colors.sh"

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

FONT="FiraCode Nerd Font Mono"
PADDINGS=2

# Setting up the general bar appearance and default values
sketchybar --bar height=41                                                    \
                     position=top                                             \
                     sticky=on                                                \
                     color=$BASE                                              \
                     border_width=2                                           \
                     border_color=$REDALT                                     \
                     y_offset=-2                                              \
                     margin=-2                                                \
                     notch_width=210                                          \
           --default updates=when_shown                                       \
                     icon.font="$FONT:Retina:16.0"                            \
                     icon.color=$ICON_COLOR                                   \
                     icon.padding_left=$PADDINGS                              \
                     icon.padding_right=$PADDINGS                             \
                     label.font="$FONT:SemiBold:12.0"                         \
                     label.color=$LABEL_COLOR                                 \
                     label.padding_left=$PADDINGS                             \
                     label.padding_right=$PADDINGS                            \
                     padding_right=$PADDINGS                                  \
                     padding_left=$PADDINGS                                   \
                     background.height=32                                     \
                     popup.background.border_width=2                          \
                     popup.background.corner_radius=9                         \
                     popup.background.border_color=$PEACH                     \
                     popup.background.color=$BASE                             \
                     popup.background.shadow.drawing=on                       \
           --add event screen_unlock "com.apple.screenIsUnlocked" 
# -- }}}

# -- {{{ spaces
MAIN_DISPLAY_ICONS=("1" "2" "3" "4" "5" "6" "7" "8" "9" "0")
SECONDARY_DISPLAY_ICONS=("1Ő≤ " "2Ő≤" "3Ő≤" "4Ő≤" "5Ő≤" "6Ő≤")
SPACE_ICONS=("${MAIN_DISPLAY_ICONS[@]}" "${SECONDARY_DISPLAY_ICONS[@]}")

# Destroy space on right click, focus space on left click.
# New space by left clicking separator (>)
sketchybar --add event refresh_spaces

sid=0
spaces=()
for i in "${!SPACE_ICONS[@]}"
do
  sid=$(($i+1))
  sketchybar --add space space.$sid left                                      \
             --set space.$sid associated_space=$sid                           \
                              script="$PLUGIN_DIR/space.sh"                   \
                              width=20                                        \
                              align=center                                    \
                              label.drawing=off                               \
                              label.padding_left=0                            \
                              label.padding_right=0                           \
                              icon=${SPACE_ICONS[i]}                          \
                              icon.width=16                                   \
                              icon.align=center                               \
                              icon.font="$FONT:SemiBold:11.0"                 \
                              icon.color=$FG2                                 \
                              icon.highlight_color=$FG2                       \
                              icon.padding_left=1                             \
                              icon.padding_right=0                            \
                              background.color=$BG1                           \
                              background.corner_radius=5                      \
                              background.height=20                            \
            --subscribe space.$sid mouse.clicked refresh_spaces 
done
# -- }}}
# -- {{{ calendar
sketchybar --add item calendar right                                          \
           --set calendar update_freq=21                                      \
                       icon="ůį•Ē"                                               \
                       icon.font="$FONT:Retina:18.0"                          \
                       icon.padding_right=4                                   \
                       icon.color=$BLUE                                       \
                       icon.y_offset=2                                        \
                       label.y_offset=1                                       \
                       label.font="$FONT:SemiBold:12"                         \
                       label.color=$BLUE                                      \
                       label.padding_right=8                                  \
                       background.color=$BLUE                                 \
                       background.height=2                                    \
                       background.padding_right=6                             \
                       background.y_offset=-9                                 \
                       script="$PLUGIN_DIR/calendar.sh"                       \
                       icon.padding_left=0                                    \
                       label.padding_right=1                                  \
            --subscribe calendar system_woke screen_unlock 
# -- }}}
